---
import BaseLayout from '../layouts/BaseLayout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects');
const featuredProjects = allProjects
  .filter((p) => p.data.featured)
  .sort((a, b) => b.data.year - a.data.year);

// Hero Vimeo showreel
const heroVideoId = '97920566';
const heroEmbedSrc = `https://player.vimeo.com/video/${heroVideoId}?autoplay=1&muted=1&loop=1&background=1`;
---

<BaseLayout
  title="Isaac Musoke — Filmskaber · DOP · Skuespiller"
  description="Jeg ser det, der glemmes. Jeg fortæller det, der gælder. Isaac Musoke er dansk-ugandisk filmskaber, DOP og skuespiller baseret i Danmark."
>
  <!-- HERO -->
  <section class="hero" aria-label="Forsideintro">
    <!-- Vimeo background embed -->
    <div class="hero-video-container" aria-hidden="true">
      <iframe
        class="hero-iframe"
        src={heroEmbedSrc}
        allow="autoplay; fullscreen; picture-in-picture"
        title="Isaac Musoke — showreel"
        aria-hidden="true"
        tabindex="-1"
      ></iframe>
    </div>

    <!-- Fallback (shown when iframe fails or JS is off) -->
    <div class="hero-fallback" aria-hidden="true"></div>

    <!-- Overlay content -->
    <div class="hero-content">
      <div class="hero-ordmark-wrap">
        <a href="/" class="ordmark ordmark--hero hero-ordmark" aria-label="Isaac Musoke — forsiden">
          ISAAC MUSOKE
        </a>
      </div>
      <p class="hero-tagline type-h2">
        Jeg ser det, der glemmes.<br />
        Jeg fortæller det, der gælder.
      </p>
      <a href="/work" class="hero-cta type-label">
        Se arbejdet
        <svg width="16" height="16" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
          <path d="M221.66,133.66l-72,72a8,8,0,0,1-11.32-11.32L196.69,136H40a8,8,0,0,1,0-16H196.69L138.34,61.66a8,8,0,0,1,11.32-11.32l72,72A8,8,0,0,1,221.66,133.66Z"/>
        </svg>
      </a>
    </div>

    <!-- Scroll cue -->
    <div class="scroll-cue" aria-hidden="true">
      <svg width="20" height="20" viewBox="0 0 256 256" fill="currentColor">
        <path d="M213.66,101.66l-80,80a8,8,0,0,1-11.32,0l-80-80A8,8,0,0,1,53.66,90.34L128,164.69l74.34-74.35a8,8,0,0,1,11.32,11.32Z"/>
      </svg>
    </div>
  </section>

  <!-- FEATURED PROJECTS -->
  <section class="featured" aria-labelledby="featured-heading">
    <div class="container">
      <p class="featured-label type-label" id="featured-heading" aria-label="Sektion: udvalgte projekter">
        UDVALGTE PROJEKTER
      </p>
      <div class="featured-grid">
        {featuredProjects.map((project) => (
          <ProjectCard
            title={project.data.title}
            slug={project.slug}
            year={project.data.year}
            category={project.data.category}
            poster={project.data.poster}
            excerpt={project.data.excerpt}
            clip_url={project.data.clip_url}
            featured={project.data.featured}
          />
        ))}
      </div>
      <div class="featured-more">
        <a href="/work" class="btn-outline type-label">
          Se alt arbejde
          <svg width="14" height="14" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
            <path d="M221.66,133.66l-72,72a8,8,0,0,1-11.32-11.32L196.69,136H40a8,8,0,0,1,0-16H196.69L138.34,61.66a8,8,0,0,1,11.32-11.32l72,72A8,8,0,0,1,221.66,133.66Z"/>
          </svg>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* ---- HERO ---- */
  .hero {
    position: relative;
    width: 100%;
    height: 100dvh;
    min-height: 600px;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    background-color: var(--color-bg);
  }

  .hero-video-container {
    position: absolute;
    inset: -10%;
    z-index: 0;
    pointer-events: none;
  }

  .hero-iframe {
    width: 100%;
    height: 100%;
    border: none;
    object-fit: cover;
  }

  /* Fallback dark overlay behind video (also shown if iframe doesn't load) */
  .hero-fallback {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: linear-gradient(
      135deg,
      rgba(8, 8, 8, 0.6) 0%,
      rgba(8, 8, 8, 0.4) 100%
    );
  }

  /* Gradient scrim for legibility */
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
    background: linear-gradient(
      to top,
      rgba(8, 8, 8, 0.95) 0%,
      rgba(8, 8, 8, 0.4) 50%,
      rgba(8, 8, 8, 0.2) 100%
    );
    pointer-events: none;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-xl);
    padding-bottom: var(--space-4xl);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-lg);
  }

  .hero-ordmark-wrap {
    /* The ordmark sits in the top-left; override absolute for hero context */
  }

  .hero-ordmark {
    font-size: clamp(16px, 2.5vw, 22px);
  }

  .hero-tagline {
    color: var(--color-text-primary);
    max-width: 600px;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-accent-1);
    padding: var(--space-sm) var(--space-lg);
    border: 1px solid rgba(0, 153, 255, 0.4);
    border-radius: var(--radius-sm);
    transition: background-color var(--duration-base) var(--ease-out),
                color var(--duration-base) var(--ease-out),
                border-color var(--duration-base) var(--ease-out);
  }

  .hero-cta:hover {
    background-color: var(--color-accent-1);
    color: var(--color-bg);
    border-color: var(--color-accent-1);
  }

  .scroll-cue {
    position: absolute;
    bottom: var(--space-xl);
    left: 50%;
    transform: translateX(-50%);
    z-index: 2;
    color: var(--color-text-muted);
    animation: bounce 2s ease-in-out infinite;
  }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50% { transform: translateX(-50%) translateY(6px); }
  }

  /* ---- FEATURED PROJECTS ---- */
  .featured {
    padding-top: var(--space-4xl);
    padding-bottom: var(--space-3xl);
  }

  .featured-label {
    color: var(--color-accent-1);
    margin-bottom: var(--space-2xl);
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-xl);
  }

  .featured-more {
    margin-top: var(--space-3xl);
    display: flex;
    justify-content: center;
  }

  .btn-outline {
    display: inline-flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--color-text-secondary);
    padding: var(--space-sm) var(--space-xl);
    border: 1px solid rgba(255, 255, 255, 0.15);
    border-radius: var(--radius-sm);
    transition: color var(--duration-base) var(--ease-out),
                border-color var(--duration-base) var(--ease-out);
  }

  .btn-outline:hover {
    color: var(--color-text-primary);
    border-color: rgba(255, 255, 255, 0.4);
  }

  @media (max-width: 1024px) {
    .featured-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .featured-grid {
      grid-template-columns: 1fr;
    }

    .hero-content {
      padding-inline: var(--space-md);
      padding-bottom: var(--space-3xl);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-cue {
      animation: none;
    }

    .hero-cta,
    .btn-outline {
      transition: none;
    }
  }
</style>

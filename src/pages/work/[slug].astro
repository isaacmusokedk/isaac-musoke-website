---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((project) => ({
    params: { slug: project.data.slug },
    props: { project },
  }));
}

interface Props {
  project: CollectionEntry<'projects'>;
}

const { project } = Astro.props;
const { Content } = await project.render();

const allProjects = await getCollection('projects');
const sorted = allProjects.sort((a, b) => b.data.year - a.data.year);
const currentIndex = sorted.findIndex((p) => p.data.slug === project.data.slug);
const prevProject = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;
const nextProject = currentIndex > 0 ? sorted[currentIndex - 1] : null;

const { title, year, role, client, category, poster, embed_url, stills, excerpt } = project.data;

const categoryColors: Record<string, string> = {
  Musik: 'var(--color-accent-2)',
  Poesi: 'var(--color-accent-3)',
  Filmbusiness: 'var(--color-accent-1)',
};

const accentColor = categoryColors[category] ?? 'var(--color-accent-1)';
---

<BaseLayout
  title={`${title} — Isaac Musoke`}
  description={excerpt}
  ogImage={poster}
>
  <article class="project-page" aria-labelledby="project-title">

    <!-- HERO: Vimeo embed or poster image -->
    <section class="project-hero" aria-label="Projektets visuelle intro">
      {embed_url ? (
        <div class="video-wrapper hero-video" aria-label={`Video: ${title}`}>
          <iframe
            src={embed_url}
            allow="autoplay; fullscreen; picture-in-picture"
            allowfullscreen
            title={title}
          ></iframe>
        </div>
      ) : (
        <div class="hero-image-wrap">
          <img
            src={poster}
            alt={`Poster for ${title}`}
            width="1280"
            height="720"
            loading="eager"
            decoding="async"
            class="hero-image"
          />
        </div>
      )}
    </section>

    <div class="project-body container">

      <!-- Meta bar -->
      <header class="project-header">
        <h1 class="type-h1 project-title" id="project-title">{title}</h1>

        <div class="meta-bar" role="list" aria-label="Projektdetaljer">
          <div class="meta-item" role="listitem">
            <span class="type-label meta-label">År</span>
            <span class="type-small meta-value">{year}</span>
          </div>
          <div class="meta-item" role="listitem">
            <span class="type-label meta-label">Rolle</span>
            <span class="type-small meta-value">{role}</span>
          </div>
          <div class="meta-item" role="listitem">
            <span class="type-label meta-label">Klient</span>
            <span class="type-small meta-value">{client}</span>
          </div>
          <div class="meta-item" role="listitem">
            <span class="type-label meta-label">Kategori</span>
            <span
              class="type-label meta-tag"
              style={`color: ${accentColor}; border-color: ${accentColor};`}
            >
              {category}
            </span>
          </div>
        </div>
      </header>

      <!-- Markdown body -->
      <div class="project-content prose">
        <Content />
      </div>

      <!-- Stills gallery -->
      {stills && stills.length > 0 && (
        <section class="stills-section" aria-labelledby="stills-heading">
          <h2 class="type-h3" id="stills-heading">Billeder fra projektet</h2>
          <div class="stills-grid" role="list">
            {stills.map((src, i) => (
              <button
                class="still-btn"
                data-src={src}
                data-index={i}
                aria-label={`Åbn billede ${i + 1} af ${stills.length}: ${title}`}
                role="listitem"
              >
                <img
                  src={src}
                  alt={`Still ${i + 1} fra ${title}`}
                  width="800"
                  height="533"
                  loading={i < 2 ? 'eager' : 'lazy'}
                  decoding="async"
                  class="still-image"
                />
              </button>
            ))}
          </div>
        </section>
      )}

      <!-- Project nav: prev / next -->
      <nav class="project-nav" aria-label="Næste og forrige projekt">
        <div class="project-nav-inner">
          {prevProject ? (
            <a href={`/work/${prevProject.data.slug}`} class="project-nav-link project-nav-prev">
              <span class="type-label nav-dir">Forrige</span>
              <span class="type-h3 nav-title">{prevProject.data.title}</span>
            </a>
          ) : <span />}

          {nextProject ? (
            <a href={`/work/${nextProject.data.slug}`} class="project-nav-link project-nav-next">
              <span class="type-label nav-dir">Næste</span>
              <span class="type-h3 nav-title">{nextProject.data.title}</span>
            </a>
          ) : <span />}
        </div>
      </nav>
    </div>
  </article>

  <!-- Lightbox -->
  <div
    class="lightbox"
    id="lightbox"
    role="dialog"
    aria-modal="true"
    aria-label="Billedvisning"
    aria-hidden="true"
    hidden
    data-title={title}
  >
    <button class="lightbox-close" id="lightbox-close" aria-label="Luk billedvisning">
      <svg width="24" height="24" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
        <path d="M205.66,194.34a8,8,0,0,1-11.32,11.32L128,139.31,61.66,205.66a8,8,0,0,1-11.32-11.32L116.69,128,50.34,61.66A8,8,0,0,1,61.66,50.34L128,116.69l66.34-66.35a8,8,0,0,1,11.32,11.32L139.31,128Z"/>
      </svg>
    </button>
    <button class="lightbox-prev" id="lightbox-prev" aria-label="Forrige billede">
      <svg width="24" height="24" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
        <path d="M165.66,202.34a8,8,0,0,1-11.32,11.32l-80-80a8,8,0,0,1,0-11.32l80-80a8,8,0,0,1,11.32,11.32L91.31,128Z"/>
      </svg>
    </button>
    <div class="lightbox-content">
      <img id="lightbox-img" src="data:image/gif;base64,R0lGODlhAQABAAAAACH5BAEKAAEALAAAAAABAAEAAAICTAEAOw==" alt="" width="1200" height="800" />
    </div>
    <button class="lightbox-next" id="lightbox-next" aria-label="Næste billede">
      <svg width="24" height="24" viewBox="0 0 256 256" fill="currentColor" aria-hidden="true">
        <path d="M181.66,133.66l-80,80a8,8,0,0,1-11.32-11.32L164.69,128,90.34,53.66a8,8,0,0,1,11.32-11.32l80,80A8,8,0,0,1,181.66,133.66Z"/>
      </svg>
    </button>
    <div class="lightbox-counter" id="lightbox-counter" aria-live="polite"></div>
  </div>
</BaseLayout>

<style>
  .project-page {
    padding-bottom: var(--space-4xl);
  }

  /* HERO */
  .project-hero {
    width: 100%;
    background-color: var(--color-surface-1);
  }

  .hero-video {
    max-height: 80vh;
  }

  .hero-image-wrap {
    aspect-ratio: 16 / 9;
    max-height: 80vh;
    overflow: hidden;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* BODY */
  .project-body {
    padding-top: var(--space-3xl);
  }

  .project-title {
    color: var(--color-text-primary);
    margin-bottom: var(--space-xl);
  }

  /* Meta bar */
  .meta-bar {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xl) var(--space-2xl);
    padding: var(--space-lg) 0;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    margin-bottom: var(--space-3xl);
  }

  .meta-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .meta-label {
    color: var(--color-text-muted);
  }

  .meta-value {
    color: var(--color-text-secondary);
    font-weight: 500;
  }

  .meta-tag {
    border: 1px solid;
    border-radius: var(--radius-sm);
    padding: 2px var(--space-sm);
    align-self: flex-start;
  }

  /* Prose (markdown content) */
  .prose {
    max-width: 720px;
    color: var(--color-text-secondary);
    line-height: 1.75;
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(20px, 3vw, 28px);
    color: var(--color-text-primary);
    margin-top: var(--space-3xl);
    margin-bottom: var(--space-md);
    letter-spacing: 0.06em;
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(16px, 2.5vw, 22px);
    color: var(--color-text-primary);
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-sm);
    letter-spacing: 0.08em;
  }

  .prose :global(p) {
    margin-bottom: var(--space-lg);
  }

  .prose :global(ul),
  .prose :global(ol) {
    list-style: disc;
    padding-left: var(--space-xl);
    margin-bottom: var(--space-lg);
  }

  .prose :global(ol) {
    list-style: decimal;
  }

  .prose :global(li) {
    margin-bottom: var(--space-xs);
  }

  .prose :global(strong) {
    color: var(--color-text-primary);
    font-weight: 600;
  }

  .prose :global(em) {
    font-style: italic;
  }

  .prose :global(a) {
    color: var(--color-accent-1);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  /* Stills gallery */
  .stills-section {
    margin-top: var(--space-4xl);
  }

  .stills-section h2 {
    color: var(--color-text-primary);
    margin-bottom: var(--space-xl);
  }

  .stills-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-md);
  }

  .still-btn {
    display: block;
    cursor: pointer;
    border-radius: var(--radius-md);
    overflow: hidden;
    border: 2px solid transparent;
    transition: border-color var(--duration-fast) var(--ease-out);
    aspect-ratio: 3 / 2;
  }

  .still-btn:hover,
  .still-btn:focus-visible {
    border-color: var(--color-accent-1);
  }

  .still-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform var(--duration-slow) var(--ease-out);
  }

  .still-btn:hover .still-image {
    transform: scale(1.04);
  }

  /* Project nav */
  .project-nav {
    margin-top: var(--space-4xl);
    padding-top: var(--space-2xl);
    border-top: 1px solid rgba(255, 255, 255, 0.08);
  }

  .project-nav-inner {
    display: flex;
    justify-content: space-between;
    gap: var(--space-xl);
  }

  .project-nav-link {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    text-decoration: none;
    max-width: 45%;
    transition: color var(--duration-fast) var(--ease-out);
  }

  .project-nav-next {
    align-items: flex-end;
  }

  .nav-dir {
    color: var(--color-text-muted);
  }

  .nav-title {
    color: var(--color-text-secondary);
    font-size: 18px;
  }

  .project-nav-link:hover .nav-title {
    color: var(--color-accent-1);
  }

  /* LIGHTBOX */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    background-color: rgba(8, 8, 8, 0.96);
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    transition: opacity var(--duration-base) var(--ease-out);
  }

  .lightbox:not([hidden]) {
    opacity: 1;
  }

  .lightbox-content {
    max-width: 90vw;
    max-height: 90vh;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .lightbox-content img {
    max-width: 100%;
    max-height: 90vh;
    object-fit: contain;
    border-radius: var(--radius-md);
  }

  .lightbox-close,
  .lightbox-prev,
  .lightbox-next {
    position: fixed;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.08);
    color: var(--color-text-primary);
    transition: background-color var(--duration-fast) var(--ease-out);
    cursor: pointer;
    border: none;
  }

  .lightbox-close:hover,
  .lightbox-prev:hover,
  .lightbox-next:hover {
    background-color: rgba(255, 255, 255, 0.16);
  }

  .lightbox-close {
    top: var(--space-xl);
    right: var(--space-xl);
  }

  .lightbox-prev {
    left: var(--space-xl);
    top: 50%;
    transform: translateY(-50%);
  }

  .lightbox-next {
    right: var(--space-xl);
    top: 50%;
    transform: translateY(-50%);
  }

  .lightbox-counter {
    position: fixed;
    bottom: var(--space-xl);
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-body);
    font-size: 14px;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .stills-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .project-nav-inner {
      flex-direction: column;
    }

    .project-nav-link {
      max-width: 100%;
    }

    .project-nav-next {
      align-items: flex-start;
    }
  }

  @media (max-width: 480px) {
    .stills-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .lightbox,
    .still-btn,
    .still-image,
    .project-nav-link,
    .lightbox-close,
    .lightbox-prev,
    .lightbox-next {
      transition: none;
    }

    .still-btn:hover .still-image {
      transform: none;
    }
  }
</style>

<script>
  // Minimal vanilla JS lightbox
  const stills = Array.from(document.querySelectorAll<HTMLButtonElement>('.still-btn'));
  const lightbox = document.getElementById('lightbox') as HTMLDivElement | null;
  const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement | null;
  const lightboxClose = document.getElementById('lightbox-close');
  const lightboxPrev = document.getElementById('lightbox-prev');
  const lightboxNext = document.getElementById('lightbox-next');
  const lightboxCounter = document.getElementById('lightbox-counter');

  let currentIndex = 0;
  let previouslyFocused: HTMLElement | null = null;

  function openLightbox(index: number) {
    if (!lightbox || !lightboxImg) return;
    currentIndex = index;
    const btn = stills[index];
    const src = btn.dataset.src ?? '';
    const img = btn.querySelector('img');

    lightboxImg.src = src;
    lightboxImg.alt = img?.alt ?? `Stillbillede ${currentIndex + 1} fra ${lightbox.dataset.title ?? ''}`;
    lightbox.hidden = false;
    lightbox.removeAttribute('aria-hidden');
    updateCounter();

    // Force reflow to allow opacity transition
    lightbox.getBoundingClientRect();
    lightbox.style.opacity = '1';

    document.body.style.overflow = 'hidden';
    previouslyFocused = document.activeElement as HTMLElement;
    lightboxClose?.focus();
  }

  function closeLightbox() {
    if (!lightbox) return;
    lightbox.style.opacity = '0';
    setTimeout(() => {
      lightbox.hidden = true;
      lightbox.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
      previouslyFocused?.focus();
    }, 200);
  }

  function navigate(direction: number) {
    const newIndex = (currentIndex + direction + stills.length) % stills.length;
    openLightbox(newIndex);
  }

  function updateCounter() {
    if (lightboxCounter) {
      lightboxCounter.textContent = `${currentIndex + 1} / ${stills.length}`;
    }
  }

  stills.forEach((btn, i) => {
    btn.addEventListener('click', () => openLightbox(i));
  });

  lightboxClose?.addEventListener('click', closeLightbox);
  lightboxPrev?.addEventListener('click', () => navigate(-1));
  lightboxNext?.addEventListener('click', () => navigate(1));

  // Click backdrop to close
  lightbox?.addEventListener('click', (e) => {
    if (e.target === lightbox) closeLightbox();
  });

  // Keyboard navigation
  document.addEventListener('keydown', (e) => {
    if (!lightbox || lightbox.hidden) return;
    switch (e.key) {
      case 'Escape':
        closeLightbox();
        break;
      case 'ArrowLeft':
        navigate(-1);
        break;
      case 'ArrowRight':
        navigate(1);
        break;
      case 'Tab': {
        const focusable = [lightboxClose, lightboxPrev, lightboxNext].filter(Boolean);
        const first = focusable[0];
        const last = focusable[focusable.length - 1];
        if (e.shiftKey && document.activeElement === first) {
          e.preventDefault();
          last.focus();
        } else if (!e.shiftKey && document.activeElement === last) {
          e.preventDefault();
          first.focus();
        }
        break;
      }
    }
  });
</script>
